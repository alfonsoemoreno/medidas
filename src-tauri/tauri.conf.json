{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Escala y Medición",
  "version": "0.1.0",
  "identifier": "com.alfonsomoreno.escalamedicion",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Escala y Medición",
        "width": 1480,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Calibración y medición visual para imágenes de microscopio.",
    "longDescription": "Aplicación de escritorio para calibrar escalas, medir muestras y exportar resultados sobre imágenes de microscopio.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
